# ============================================================
# AI SUPPORT PORTAL — Environment Variables
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in each value below
# 3. Never commit your actual .env file (it's already in .gitignore)
# ============================================================

# PostgreSQL Database URL
# Local example: postgresql://postgres:YOUR_PASSWORD@localhost:5432/support_portal
# Neon (cloud) example: postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/support_portal"

# NextAuth Secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="paste-your-generated-secret-here"

# NextAuth URL — use http://localhost:3000 locally,
# or your live Vercel URL (e.g. https://project-nr996.vercel.app) in production
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini API Key — get a free key at:
# https://aistudio.google.com/apikey
GEMINI_API_KEY="paste-your-gemini-api-key-here"